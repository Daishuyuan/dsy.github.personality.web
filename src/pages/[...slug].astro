---
import EngagementPanel from "../features/engagement/components/EngagementPanel.vue";
import ContentSourceError from "../features/content/components/ContentSourceError.astro";
import { findPublicArticleByPath, getPublicCacheHeaders, getPublicContentErrorMessage } from "../features/content/source";
import BaseLayout from "../layouts/BaseLayout.astro";
import { formatDate, getPostArticleId } from "../lib/posts";
import type { BlogPost } from "../lib/posts";

for (const [name, value] of Object.entries(getPublicCacheHeaders())) {
  Astro.response.headers.set(name, value);
}

const slug = `/${String(Astro.params.slug ?? "").replace(/^\/+|\/+$/g, "")}/`;
let contentError = "";
let post: BlogPost | null = null;
try {
  post = await findPublicArticleByPath(slug);
} catch (error) {
  contentError = getPublicContentErrorMessage(error);
}
if (!post && !contentError) {
  return new Response("Not found", { status: 404 });
}
const articleId = post ? getPostArticleId(post) : "";
---

<BaseLayout title={post ? `${post.title} | Daishuyuan` : "文章数据库不可用 | Daishuyuan"}>
  {contentError ? (
    <ContentSourceError message={contentError} />
  ) : (
    <article class="article-shell">
      <header class="article-header">
        <time datetime={post.publishedDate}>{formatDate(post.publishedDate)}</time>
        <h1>{post.title}</h1>
        <ul class="tag-row" aria-label={`${post.title} tags`}>
          {post.tags.map((tag: string) => (
            <li><a href={`/tags/${encodeURIComponent(tag)}/`}>{tag}</a></li>
          ))}
        </ul>
      </header>
      <div class="article-content">
        <Fragment set:html={post.renderedHtml} />
      </div>
      <EngagementPanel client:only="vue" articleId={articleId} title={post.title} />
    </article>
  )}
</BaseLayout>
