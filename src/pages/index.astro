---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { formatDate, getAllTags, getPostPath, sortPosts } from "../lib/posts";

const posts = sortPosts(await getCollection("blog"));
const tags = getAllTags(posts);
---

<BaseLayout title="Daishuyuan">
  <section class="intro">
    <p class="eyebrow">Technical Notes</p>
    <h1>Daishuyuan</h1>
    <p>软件工程、算法、架构和机器学习笔记。</p>
  </section>

  <section class="content-grid" aria-label="Blog overview">
    <div class="post-list">
      {posts.map((post) => (
        <article class="post-card">
          <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
          <h2><a href={getPostPath(post)}>{post.data.title}</a></h2>
          <ul class="tag-row" aria-label={`${post.data.title} tags`}>
            {post.data.tags.map((tag) => (
              <li><a href={`/tags/${encodeURIComponent(tag)}/`}>{tag}</a></li>
            ))}
          </ul>
        </article>
      ))}
    </div>

    <aside class="side-panel" aria-label="Navigation summary">
      <section>
        <h2>归档</h2>
        <a class="text-link" href="/archives/">全部文章</a>
      </section>
      <section>
        <h2>标签</h2>
        <div class="tag-cloud">
          {tags.map((tag) => (
            <a href={`/tags/${encodeURIComponent(tag)}/`}>{tag}</a>
          ))}
        </div>
      </section>
    </aside>
  </section>
</BaseLayout>
