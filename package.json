{
  "name": "dsy-github-personality-web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check:site": "node scripts/check-generated-site.mjs",
    "check:content": "node scripts/check-blog-content-unchanged.mjs",
    "cleanup:engagement-legacy": "node scripts/cleanup-engagement-legacy-data.mjs --apply",
    "test:algorithms": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:preview": "npm run build && PLAYWRIGHT_BASE_URL=http://127.0.0.1:4322 PLAYWRIGHT_SERVER_URL=http://127.0.0.1:4322 PLAYWRIGHT_SERVER_COMMAND=\"npm run preview -- --host 127.0.0.1 --port 4322\" playwright test",
    "verify": "npm run build && npm run check:site && npm run check:content && npm run test:algorithms"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.6.0",
    "@astrojs/vue": "^6.0.1",
    "astro": "^6.0.0",
    "element-plus": "^2.14.2",
    "mongodb": "^7.3.0",
    "vue": "^3.5.38"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "extend": "^3.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
