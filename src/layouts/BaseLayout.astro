---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Daishuyuan",
  description = "A bilingual personal notebook on software engineering, algorithms, architecture, and machine learning."
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="/assets/img/face.jpg" />
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <div class="site-ground" aria-hidden="true"></div>
    <header class="site-header">
      <div class="brand">
        <a class="brand-mark" href="/admin/" aria-label="进入后台">笺</a>
        <a class="brand-copy" href="/" aria-label="Daishuyuan home">
          <strong>Daishuyuan</strong>
          <small>技术札记 / Field Notes</small>
        </a>
      </div>
      <nav aria-label="Primary">
        <a href="/" aria-label="Essays"><span>文章</span><small>Essays</small></a>
        <a href="/visual-algorithms/" aria-label="Visual Algorithm Lab"><span>可视化算法</span><small>Visual Lab</small></a>
        <a href="/archives/" aria-label="Archive"><span>归档</span><small>Archive</small></a>
        <a href="/tags/" aria-label="Tags"><span>标签</span><small>Tags</small></a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <span>Daishuyuan</span>
      <span>以代码格物，以文字存思 / Thinking through code, keeping notes in words.</span>
    </footer>
  </body>
</html>
