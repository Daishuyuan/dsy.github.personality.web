---
import { getCollection, render } from "astro:content";
import EngagementPanel from "../features/engagement/components/EngagementPanel.vue";
import BaseLayout from "../layouts/BaseLayout.astro";
import { formatDate, getPostArticleId, getPostPath } from "../lib/posts";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: getPostPath(post).replace(/^\/|\/$/g, "") },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const articleId = getPostArticleId(post);
---

<BaseLayout title={`${post.data.title} | Daishuyuan`}>
  <article class="article-shell">
    <header class="article-header">
      <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
      <h1>{post.data.title}</h1>
      <ul class="tag-row" aria-label={`${post.data.title} tags`}>
        {post.data.tags.map((tag: string) => (
          <li><a href={`/tags/${encodeURIComponent(tag)}/`}>{tag}</a></li>
        ))}
      </ul>
    </header>
    <div class="article-content">
      <Content />
    </div>
    <EngagementPanel client:only="vue" articleId={articleId} title={post.data.title} />
  </article>
</BaseLayout>
