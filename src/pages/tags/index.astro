---
import ContentSourceError from "../../features/content/components/ContentSourceError.astro";
import { getPublicArticles, getPublicContentErrorMessage } from "../../features/content/source";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllTags } from "../../lib/posts";
import type { BlogPost } from "../../lib/posts";

let contentError = "";
let posts: BlogPost[] = [];
let tags: string[] = [];
try {
  posts = await getPublicArticles();
  tags = getAllTags(posts);
} catch (error) {
  contentError = getPublicContentErrorMessage(error);
}
---

<BaseLayout title="标签 | Daishuyuan">
  <section class="page-heading">
    <p class="eyebrow">Tags</p>
    <h1>标签</h1>
    <p>按主题进入算法、架构、论文与工程实践笔记。</p>
  </section>

  {contentError ? (
    <ContentSourceError message={contentError} />
  ) : (
    <nav class="tag-index" aria-label="All tags">
      {tags.map((tag) => (
        <a href={`/tags/${encodeURIComponent(tag)}/`}>
          <span>{tag}</span>
          <strong>{posts.filter((post) => post.tags.includes(tag)).length}</strong>
        </a>
      ))}
    </nav>
  )}
</BaseLayout>
